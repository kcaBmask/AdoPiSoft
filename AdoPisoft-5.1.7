#!/bin/bash
# ======================================================
# AdoPiSoft + PostgreSQL Automated Installation Script
# Ubuntu Server 24.04 (x64/x86_64)
# ======================================================

set -e

# --- Require root ---
if [ "$EUID" -ne 0 ]; then
    echo "======================================================"
    echo "⚠️  Run this script as root!"
    echo "Example: sudo bash install_adopisoft.sh"
    echo "======================================================"
    exit 1
fi

GREEN="\e[32m"
YELLOW="\e[33m"
RED="\e[31m"
NC="\e[0m"

export DEBIAN_FRONTEND=noninteractive

echo -e "${GREEN}"
echo "======================================================"
echo "      AdoPiSoft + PostgreSQL Automated Installer"
echo "======================================================"
echo -e "${NC}"

sleep 2

# ------------------------------------------------------
# UPDATE SYSTEM
# ------------------------------------------------------

echo -e "${YELLOW}[1/10] Updating system...${NC}"
apt-get update -y
apt-get upgrade -y

# ------------------------------------------------------
# INSTALL BASIC UTILITIES
# ------------------------------------------------------

echo -e "${YELLOW}[2/10] Installing core utilities...${NC}"
apt-get install -y \
curl wget zip unzip git bridge-utils \
iputils-arping dmidecode build-essential

# ------------------------------------------------------
# INSTALL NETWORK SERVICES
# ------------------------------------------------------

echo -e "${YELLOW}[3/10] Installing network services...${NC}"
apt-get install -y \
nginx bind9 isc-dhcp-server hostapd \
iptables openssh-server

# ------------------------------------------------------
# INSTALL PYTHON
# ------------------------------------------------------

echo -e "${YELLOW}[4/10] Installing Python...${NC}"

if apt-get install -y python-is-python3 python3-pip; then
    echo -e "${GREEN}Python3 installed.${NC}"
else
    echo -e "${RED}Python install failed.${NC}"
    exit 1
fi

# ------------------------------------------------------
# NODEJS 16 SETUP
# ------------------------------------------------------

echo -e "${YELLOW}[5/10] Installing NodeJS 16.x...${NC}"

curl -fsSL https://deb.nodesource.com/setup_16.x | bash -

apt-get install -y nodejs

# ------------------------------------------------------
# INSTALL POSTGRESQL
# ------------------------------------------------------

echo -e "${YELLOW}[6/10] Installing PostgreSQL...${NC}"

apt-get install -y postgresql postgresql-contrib

# ------------------------------------------------------
# POSTGRESQL CONFIG
# ------------------------------------------------------

echo -e "${YELLOW}[7/10] Configuring PostgreSQL...${NC}"

DB_USER="adopisoft"
DB_PASS="adopisoft"
DB_NAME="adopisoft"

sudo -u postgres psql -c "ALTER USER postgres WITH PASSWORD '${DB_PASS}';"

sudo -u postgres psql -tc "SELECT 1 FROM pg_roles WHERE rolname='${DB_USER}'" | grep -q 1 || \
sudo -u postgres psql -c "CREATE USER ${DB_USER} WITH PASSWORD '${DB_PASS}';"

sudo -u postgres psql -tc "SELECT 1 FROM pg_database WHERE datname='${DB_NAME}'" | grep -q 1 || \
sudo -u postgres createdb -O ${DB_USER} ${DB_NAME}

systemctl enable postgresql
systemctl restart postgresql

# ------------------------------------------------------
# DOWNLOAD ADOPISOFT
# ------------------------------------------------------

echo -e "${YELLOW}[8/10] Downloading AdoPiSoft...${NC}"

wget -O /tmp/adopisoft.deb \
https://github.com/AdoPiSoft/Releases/releases/download/v5.1.7-20260106/adopisoft-5.1.7-20260106-amd64-node-v16.20.2.deb

# ------------------------------------------------------
# INSTALL ADOPISOFT
# ------------------------------------------------------

echo -e "${YELLOW}[9/10] Installing AdoPiSoft...${NC}"

apt-get install -y /tmp/adopisoft.deb

systemctl enable adopisoft
systemctl restart adopisoft

# ------------------------------------------------------
# SECURITY HARDENING
# ------------------------------------------------------

echo -e "${YELLOW}[10/10] Disabling SSH (optional security)...${NC}"

systemctl disable ssh || true

# ------------------------------------------------------
# FINISH
# ------------------------------------------------------

echo -e "${GREEN}"
echo "======================================================"
echo "     Installation Completed Successfully!"
echo "======================================================"
echo -e "${NC}"

echo
echo "Database Settings:"
echo "------------------------------------"
echo "Database Type : postgres"
echo "Host/IP       : localhost"
echo "Port          : 5432"
echo "Database      : ${DB_NAME}"
echo "Username      : ${DB_USER}"
echo "Password      : ${DB_PASS}"
echo "------------------------------------"

echo
echo -e "${YELLOW}System rebooting in 10 seconds...${NC}"

sleep 10
reboot
