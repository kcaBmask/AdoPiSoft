#!/bin/bash

# Adopisoft 5.1.7-20260106 Installer & PostgreSQL Setup

# Target System: Ubuntu Server (amd64)

# Note: 'set -e' intentionally omitted to prevent crashes on minor apt warnings

echo "======================================"
echo " Adopisoft 5.1.7-20260106 Installer"
echo " Target System: Ubuntu Server (amd64)"
echo "======================================"

# --------------------------------------------------

# Function: Secure Password Prompt

# --------------------------------------------------

read_password() {
local prompt="$1"
local var_name="$2"
local p1 p2

```
while true; do
    read -rsp "$prompt: " p1
    echo
    read -rsp "Confirm $prompt: " p2
    echo

    if [[ -z "$p1" ]]; then
        echo "Error: Password cannot be empty."
    elif [[ "$p1" != "$p2" ]]; then
        echo "Error: Passwords do not match."
    else
        eval "$var_name=\"\$p1\""
        break
    fi
done
```

}

# --------------------------------------------------

# PostgreSQL Password Prompt

# --------------------------------------------------

echo
echo "🔐 PostgreSQL Password Setup"
echo "Please set a password for the PostgreSQL 'postgres' user."
read_password "PostgreSQL Password" DB_PASSWORD

# --------------------------------------------------

# [1/9] System Update

# --------------------------------------------------

echo
echo "[1/9] Updating system..."

sudo apt-get update -q
sudo apt-get upgrade -y -q

# --------------------------------------------------

# [2/9] Install Dependencies

# --------------------------------------------------

echo
echo "[2/9] Installing required packages..."

sudo apt-get install -y -q --no-install-recommends curl wget zip unzip jq git build-essential openssh-server dmidecode bridge-utils iputils-arping nginx bind9 isc-dhcp-server iptables hostapd python3 python3-pip postgresql postgresql-contrib

if [[ $? -ne 0 ]]; then
echo "❌ Failed to install required packages."
exit 1
fi

# Fix python command

if [[ ! -e /usr/bin/python ]]; then
sudo ln -s "$(which python3)" /usr/bin/python
echo "  -> Created /usr/bin/python symlink."
else
echo "  -> Python symlink already exists."
fi

# --------------------------------------------------

# [3/9] Install Node.js 16

# --------------------------------------------------

echo
echo "[3/9] Installing Node.js 16..."

curl -fsSL https://deb.nodesource.com/setup_16.x | sudo -E bash -

if [[ $? -ne 0 ]]; then
echo "❌ Failed to configure NodeSource repository."
exit 1
fi

sudo apt-get install -y -q nodejs

if ! command -v node >/dev/null 2>&1; then
echo "❌ Node.js installation failed."
exit 1
fi

echo "  -> Node.js Version: $(node -v)"
echo "  -> NPM Version:     $(npm -v)"

# --------------------------------------------------

# [4/9] Configure PostgreSQL

# --------------------------------------------------

echo
echo "[4/9] Configuring PostgreSQL..."

sudo systemctl enable postgresql
sudo systemctl start postgresql

echo "  -> Waiting for PostgreSQL..."

until sudo -u postgres psql -c '\q' >/dev/null 2>&1; do
sleep 2
done

echo "  -> Setting postgres password..."

sudo -u postgres psql >/dev/null <<EOF
ALTER USER postgres WITH PASSWORD '$DB_PASSWORD';
EOF

echo "  -> Creating adopisoft database..."

sudo -u postgres psql -tc "SELECT 1 FROM pg_database WHERE datname='adopisoft';" | grep -q 1 || sudo -u postgres createdb adopisoft

sudo service postgresql reload

echo "  -> PostgreSQL configured successfully."

# --------------------------------------------------

# [5/9] Download Adopisoft

# --------------------------------------------------

echo
echo "[5/9] Downloading Adopisoft..."

DEB_FILE="/tmp/adopisoft-5.1.7-20260106.deb"
DEB_URL="https://github.com/AdoPiSoft/Releases/releases/download/v5.1.7-20260106/adopisoft-5.1.7-20260106-amd64-node-v16.20.2.deb"

wget -O "$DEB_FILE" "$DEB_URL"

if [[ ! -s "$DEB_FILE" ]]; then
echo "❌ Download failed."
exit 1
fi

echo "  -> Download completed."

# --------------------------------------------------

# [6/9] Install Adopisoft

# --------------------------------------------------

echo
echo "[6/9] Installing Adopisoft..."

sudo dpkg -i "$DEB_FILE"

if [[ $? -ne 0 ]]; then
echo "  -> Resolving dependencies..."
sudo apt-get install -f -y -q
fi

rm -f "$DEB_FILE"

# --------------------------------------------------

# [7/9] Enable Adopisoft Service

# --------------------------------------------------

echo
echo "[7/9] Starting Adopisoft service..."

sudo systemctl enable adopisoft
sudo systemctl restart adopisoft

sleep 3

# --------------------------------------------------

# [8/9] Verify Services

# --------------------------------------------------

echo
echo "[8/9] Verifying services..."

POSTGRES_OK=false
ADOPISOFT_OK=false

if sudo systemctl is-active --quiet postgresql; then
POSTGRES_OK=true
echo "  ✅ PostgreSQL is running"
else
echo "  ❌ PostgreSQL is NOT running"
fi

if sudo systemctl is-active --quiet adopisoft; then
ADOPISOFT_OK=true
echo "  ✅ Adopisoft is running"
else
echo "  ❌ Adopisoft is NOT running"
fi

SERVER_IP=$(hostname -I | awk '{print $1}')

echo
echo "Database Settings:"
echo "------------------------------------"
echo "Database Type : postgres"
echo "Host/IP       : localhost"
echo "Port          : 5432"
echo "Database      : adopisoft"
echo "Username      : postgres"
echo "Password      : ********"
echo "------------------------------------"

echo
echo "Adopisoft URL:"
echo "------------------------------------"
echo "http://${SERVER_IP}"
echo "------------------------------------"

echo
echo "Useful Commands:"
echo "------------------------------------"
echo "sudo systemctl status adopisoft"
echo "sudo systemctl status postgresql"
echo "journalctl -u adopisoft -f"
echo "journalctl -u postgresql -f"
echo "------------------------------------"

unset DB_PASSWORD

# --------------------------------------------------

# [9/9] Complete

# --------------------------------------------------

echo

if [ "$POSTGRES_OK" = true ] && [ "$ADOPISOFT_OK" = true ]; then
echo "======================================"
echo " ✅ Installation Completed Successfully"
echo "======================================"
else
echo "======================================"
echo " ⚠️ Installation Completed With Warnings"
echo "======================================"
fi

echo
read -p "Reboot now? (y/N): " REBOOT

if [[ "$REBOOT" =~ ^[Yy]$ ]]; then
echo "Rebooting in 5 seconds..."
sleep 5
sudo reboot
else
echo "Reboot skipped."
fi
