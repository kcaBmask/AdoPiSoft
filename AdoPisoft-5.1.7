#!/bin/bash

# ==================================================

# Adopisoft 5.1.7-20260106 + PostgreSQL Installer

# Ubuntu Server (amd64)

# ==================================================

# Colors

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Database Settings

DB_NAME="adopisoft"
DB_USER="postgres"
DB_HOST="localhost"
DB_PORT="5432"

echo "======================================"
echo " Adopisoft 5.1.7 Installer"
echo " PostgreSQL Setup Included"
echo "======================================"

# --------------------------------------------------

# Password Prompt Function

# --------------------------------------------------

read_password() {
local prompt="$1"
local var_name="$2"
local p1 p2

```
while true; do
    read -rsp "$prompt: " p1
    echo
    read -rsp "Confirm $prompt: " p2
    echo

    if [[ -z "$p1" ]]; then
        echo "Error: Password cannot be empty."
    elif [[ "$p1" != "$p2" ]]; then
        echo "Error: Passwords do not match."
    else
        eval "$var_name=\"\$p1\""
        break
    fi
done
```

}

# --------------------------------------------------

# PostgreSQL Password

# --------------------------------------------------

echo
echo "🔐 PostgreSQL Password Setup"
echo "Please set a password for the PostgreSQL superuser."
read_password "PostgreSQL Password" DB_PASSWORD

echo
echo "Password accepted."
echo

# --------------------------------------------------

# System Update

# --------------------------------------------------

echo "[1/10] Updating system..."
sudo apt-get update
sudo apt-get upgrade -y

# --------------------------------------------------

# Install Dependencies

# --------------------------------------------------

echo "[2/10] Installing dependencies..."

sudo apt-get install -y 
curl 
wget 
unzip 
zip 
jq 
git 
build-essential 
openssh-server 
dmidecode 
bridge-utils 
iputils-arping 
python3 
python3-pip 
python-is-python3 
nginx 
bind9 
isc-dhcp-server 
iptables 
hostapd

# --------------------------------------------------

# PostgreSQL Install

# --------------------------------------------------

echo "[3/10] Installing PostgreSQL..."

sudo apt-get install -y 
postgresql 
postgresql-contrib

# --------------------------------------------------

# PostgreSQL Configuration

# --------------------------------------------------

echo "[4/10] Configuring PostgreSQL..."

sudo systemctl enable postgresql
sudo systemctl start postgresql

sudo -u postgres psql <<EOF
ALTER USER postgres WITH PASSWORD '${DB_PASSWORD}';
EOF

# --------------------------------------------------

# Create Database

# --------------------------------------------------

echo "[5/10] Creating database..."

if sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='${DB_NAME}'" | grep -q 1; then
echo "Database '${DB_NAME}' already exists."
else
sudo -u postgres createdb "${DB_NAME}"
echo "Database '${DB_NAME}' created."
fi

# --------------------------------------------------

# Install Node.js 16

# --------------------------------------------------

echo "[6/10] Installing Node.js 16..."

curl -fsSL https://deb.nodesource.com/setup_16.x | sudo -E bash -

sudo apt-get install -y nodejs

echo
echo "Node Version:"
node -v

echo
echo "NPM Version:"
npm -v

# --------------------------------------------------

# Download Adopisoft

# --------------------------------------------------

echo "[7/10] Downloading Adopisoft..."

DEB_FILE="/tmp/adopisoft-5.1.7-20260106.deb"

wget -O "$DEB_FILE" 
https://github.com/AdoPiSoft/Releases/releases/download/v5.1.7-20260106/adopisoft-5.1.7-20260106-amd64-node-v16.20.2.deb

if [ ! -f "$DEB_FILE" ]; then
echo -e "${RED}ERROR: Download failed.${NC}"
exit 1
fi

# --------------------------------------------------

# Install Adopisoft

# --------------------------------------------------

echo "[8/10] Installing Adopisoft..."

sudo apt-get install -y "$DEB_FILE"

# --------------------------------------------------

# Enable Services

# --------------------------------------------------

echo "[9/10] Enabling services..."

sudo systemctl enable postgresql
sudo systemctl restart postgresql

sudo systemctl enable adopisoft
sudo systemctl restart adopisoft

# --------------------------------------------------

# Service Verification

# --------------------------------------------------

echo "[10/10] Verifying services..."

POSTGRES_OK=false
ADOPISOFT_OK=false

if sudo systemctl is-active --quiet postgresql; then
POSTGRES_OK=true
echo -e "${GREEN}✅ PostgreSQL is running${NC}"
else
echo -e "${RED}❌ PostgreSQL is NOT running${NC}"
fi

if sudo systemctl is-active --quiet adopisoft; then
ADOPISOFT_OK=true
echo -e "${GREEN}✅ Adopisoft is running${NC}"
else
echo -e "${RED}❌ Adopisoft is NOT running${NC}"
fi

echo

if [ "$POSTGRES_OK" = true ] && [ "$ADOPISOFT_OK" = true ]; then

```
echo -e "${GREEN}"
echo "======================================================"
echo "     Installation Completed Successfully!"
echo "======================================================"
echo -e "${NC}"
```

else

```
echo -e "${YELLOW}"
echo "======================================================"
echo "     Installation Completed With Warnings"
echo "======================================================"
echo -e "${NC}"
```

fi

echo
echo "Database Settings:"
echo "------------------------------------"
echo "Database Type : postgres"
echo "Host/IP       : ${DB_HOST}"
echo "Port          : ${DB_PORT}"
echo "Database      : ${DB_NAME}"
echo "Username      : ${DB_USER}"
echo "Password      : ********"
echo "------------------------------------"

echo
echo "Service Status:"
echo "------------------------------------"
systemctl is-active postgresql
systemctl is-active adopisoft
echo "------------------------------------"

SERVER_IP=$(hostname -I | awk '{print $1}')

echo
echo "Web Interface:"
echo "------------------------------------"
echo "Adopisoft URL : http://${SERVER_IP}"
echo "------------------------------------"

echo
echo "Useful Commands:"
echo "------------------------------------"
echo "sudo systemctl status adopisoft"
echo "sudo systemctl status postgresql"
echo "journalctl -u adopisoft -f"
echo "journalctl -u postgresql -f"
echo "------------------------------------"

echo
read -p "Reboot now? (y/N): " REBOOT

if [[ "$REBOOT" =~ ^[Yy]$ ]]; then
echo "Rebooting..."
sudo reboot
else
echo "Reboot skipped."
fi
